{
  "name": "@color4pen/specrunner",
  "version": "0.4.1",
  "description": "AI CI/CD runner — submit request.md, get a PR back",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/color4pen/spec-runner"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "specrunner": "dist/specrunner.js"
  },
  "scripts": {
    "build": "tsup",
    "postbuild": "! grep -qE \"from ['\\\"]zod|require\\\\(['\\\"]zod\" dist/specrunner.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./src ./tests --max-warnings 0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "@openai/codex-sdk": "^0.130.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@typescript-eslint/parser": "^8",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^4.1.5",
    "zod": "^4.0.0"
  }
}
