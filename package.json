{
  "name": "spec-runner",
  "version": "0.2.0",
  "description": "AI CI/CD runner — submit request.md, get a PR back",
  "private": true,
  "type": "module",
  "bin": {
    "specrunner": "./bin/specrunner.ts"
  },
  "scripts": {
    "build": "tsc --noEmit false --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
