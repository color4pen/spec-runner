{
  "name": "spec-runner",
  "version": "0.2.0",
  "description": "AI CI/CD runner — submit request.md, get a PR back",
  "private": true,
  "engines": {
    "bun": ">=1.0.0"
  },
  "type": "module",
  "bin": {
    "specrunner": "./dist/bin/specrunner.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./src --max-warnings 0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "@anthropic-ai/sdk": "^0.91.0",
    "@openai/codex-sdk": "^0.130.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^4.1.5"
  }
}
