{
  "name": "@color4pen/specrunner",
  "version": "0.1.8",
  "description": "AI CI/CD runner — submit request.md, get a PR back",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/color4pen/spec-runner"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": "./dist/specrunner.js"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "specrunner": "./dist/specrunner.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ./src --max-warnings 0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "@anthropic-ai/sdk": "^0.91.0",
    "@openai/codex-sdk": "^0.130.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^4.1.5"
  }
}
