ions."},{"severity":"low","file":"src/store/job-state-store.ts","title":"D7 archive-skip target line confirmed — one-line change","rationale":"The skip condition `entry.name === 'archive'` is at line 225. Adding `|| entry.name === 'canceled'` is the complete change required for D7.","line":225}]},"followUpAttempts":1,"transientRetryAttempts":0},"startedAt":"2026-06-27T00:40:13.602Z","endedAt":"2026-06-27T00:44:13.902Z"}
